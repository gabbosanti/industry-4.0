        "def save_tflite_model(tflite_bytes, path):\n",
        "    with open(path, \"wb\") as f:\n",
        "        f.write(tflite_bytes)\n",
        "\n",
        "def get_file_size_kb(path):\n",
        "    return Path(path).stat().st_size / 1024\n",
        "\n",
        "def evaluate_keras_latency(model, sample_data, n_runs=200):\n",
        "    # warm-up\n",
        "    _ = model.predict(sample_data[:1], verbose=0)\n",
        "    start = time.perf_counter()\n",
        "    for i in range(n_runs):\n",
        "        _ = model.predict(sample_data[i:i+1], verbose=0)\n",
        "    end = time.perf_counter()\n",
        "    return (end - start) / n_runs * 1000  # ms\n",
        "\n",
        "def evaluate_tflite_model(tflite_model_path, x_data, y_data):\n",
        "    interpreter = tf.lite.Interpreter(model_path=str(tflite_model_path))\n",
        "    interpreter.allocate_tensors()\n",
        "\n",
        "    input_details = interpreter.get_input_details()[0]\n",
        "    output_details = interpreter.get_output_details()[0]\n",
        "\n",
        "    input_dtype = input_details[\"dtype\"]\n",
        "    output_dtype = output_details[\"dtype\"]\n",
        "\n",
        "    input_scale, input_zero_point = input_details[\"quantization\"]\n",
        "\n",
        "    correct = 0\n",
        "\n",
        "    for i in range(len(x_data)):\n",
        "        x = x_data[i:i+1]\n",
        "\n",
        "        if input_dtype == np.float32:\n",
        "            input_tensor = x.astype(np.float32)\n",
        "        else:\n",
        "            # quantize input if required\n",
        "            input_tensor = x / input_scale + input_zero_point\n",
        "            input_tensor = np.round(input_tensor).astype(input_dtype)\n",
        "\n",
        "        interpreter.set_tensor(input_details[\"index\"], input_tensor)\n",
        "        interpreter.invoke()\n",
        "        output = interpreter.get_tensor(output_details[\"index\"])\n",
        "\n",
        "        pred = np.argmax(output, axis=1)[0]\n",
        "        if pred == y_data[i]:\n",
        "            correct += 1\n",
        "\n",
        "    return correct / len(x_data)\n",
        "\n",
        "def evaluate_tflite_latency(tflite_model_path, sample_data, n_runs=200):\n",
        "    interpreter = tf.lite.Interpreter(model_path=str(tflite_model_path))\n",
        "    interpreter.allocate_tensors()\n",
        "\n",
        "    input_details = interpreter.get_input_details()[0]\n",
        "    input_dtype = input_details[\"dtype\"]\n",
        "    input_scale, input_zero_point = input_details[\"quantization\"]\n",
        "\n",
        "    # warm-up\n",
        "    x = sample_data[:1]\n",
        "    if input_dtype == np.float32:\n",
        "        input_tensor = x.astype(np.float32)\n",
        "    else:\n",
        "        input_tensor = x / input_scale + input_zero_point\n",
        "        input_tensor = np.round(input_tensor).astype(input_dtype)\n",
        "\n",
        "    interpreter.set_tensor(input_details[\"index\"], input_tensor)\n",
        "    interpreter.invoke()\n",
        "\n",
        "    start = time.perf_counter()\n",
        "    for i in range(n_runs):\n",
        "        x = sample_data[i:i+1]\n",
        "        if input_dtype == np.float32:\n",
        "            input_tensor = x.astype(np.float32)\n",
        "        else:\n",
        "            input_tensor = x / input_scale + input_zero_point\n",
        "            input_tensor = np.round(input_tensor).astype(input_dtype)\n",
        "\n",
        "        interpreter.set_tensor(input_details[\"index\"], input_tensor)\n",
        "        interpreter.invoke()\n",
        "    end = time.perf_counter()\n",
        "\n",
        "    return (end - start) / n_runs * 1000  # ms\n",
        "\n",
        "def predict_with_tflite(tflite_model_path, x_samples):\n",
        "    interpreter = tf.lite.Interpreter(model_path=str(tflite_model_path))\n",
        "    interpreter.allocate_tensors()\n",
        "\n",
        "    input_details = interpreter.get_input_details()[0]\n",
        "    output_details = interpreter.get_output_details()[0]\n",
        "\n",
        "    input_dtype = input_details[\"dtype\"]\n",
        "    input_scale, input_zero_point = input_details[\"quantization\"]\n",
        "\n",
        "    preds = []\n",
        "    for i in range(len(x_samples)):\n",
        "        x = x_samples[i:i+1]\n",
        "        if input_dtype == np.float32:\n",
        "            input_tensor = x.astype(np.float32)\n",
        "        else:\n",
        "            input_tensor = x / input_scale + input_zero_point\n",
        "            input_tensor = np.round(input_tensor).astype(input_dtype)\n",
        "\n",
        "        interpreter.set_tensor(input_details[\"index\"], input_tensor)\n",
        "        interpreter.invoke()\n",
        "        output = interpreter.get_tensor(output_details[\"index\"])\n",
        "        preds.append(np.argmax(output, axis=1)[0])\n",
        "    return np.array(preds)\n"
